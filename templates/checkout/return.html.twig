{% extends 'base.html.twig' %}

{% block title %}Payroad — Payment Result{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex items-start justify-center pt-16 px-4">
    <div class="w-full max-w-sm">

        {# Loading #}
        <div id="state-loading" class="bg-white rounded-2xl border border-slate-200 px-8 py-12 text-center">
            <svg class="animate-spin h-8 w-8 text-indigo-500 mx-auto mb-4"
                 xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <p class="text-sm text-slate-500" id="loading-text">Confirming payment…</p>
        </div>

        {# Succeeded #}
        <div id="state-succeeded" class="hidden bg-white rounded-2xl border border-slate-200 px-8 py-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-5">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-1">Payment successful</h2>
            <p class="text-sm text-slate-500 mb-6">Your payment has been confirmed.</p>
            <div id="details-succeeded" class="text-left space-y-3 border-t border-slate-100 pt-5 mb-6"></div>
            <a href="/checkout" class="block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-3 rounded-xl transition-colors">
                New payment
            </a>
            <a href="/dashboard" class="block w-full text-center bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-semibold py-3 rounded-xl transition-colors">
                Dashboard
            </a>
        </div>

        {# Pending / Processing #}
        <div id="state-pending" class="hidden bg-white rounded-2xl border border-slate-200 px-8 py-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-100 mb-5">
                <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-1">Payment pending</h2>
            <p class="text-sm text-slate-500 mb-6">We're awaiting confirmation from the payment processor.</p>
            <div id="details-pending" class="text-left space-y-3 border-t border-slate-100 pt-5 mb-6"></div>
            <a href="/checkout" class="block w-full text-center bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold py-3 rounded-xl transition-colors">
                Back to checkout
            </a>
            <a href="/dashboard" class="block w-full text-center bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-semibold py-3 rounded-xl transition-colors">
                Dashboard
            </a>
        </div>

        {# Failed #}
        <div id="state-failed" class="hidden bg-white rounded-2xl border border-slate-200 px-8 py-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-100 mb-5">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-1">Payment failed</h2>
            <p class="text-sm text-slate-500 mb-6">Please try again with a different card.</p>
            <a href="/checkout" class="block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-3 rounded-xl transition-colors">
                Try again
            </a>
            <a href="/dashboard" class="block w-full text-center bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-semibold py-3 rounded-xl transition-colors">
                Dashboard
            </a>
        </div>

        {# Error (missing paymentId etc.) #}
        <div id="state-error" class="hidden bg-white rounded-2xl border border-red-100 px-8 py-10 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-100 mb-5">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-1">Something went wrong</h2>
            <p id="error-text" class="text-sm text-slate-500 mb-6"></p>
            <a href="/checkout" class="block w-full text-center bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold py-3 rounded-xl transition-colors">
                Back to checkout
            </a>
        </div>

        <p class="text-center text-xs text-slate-400 mt-5">
            Payroad Secure Checkout
        </p>

    </div>
</div>

<script>
(async () => {
    const params        = new URLSearchParams(window.location.search);
    const paymentId     = params.get('paymentId');
    const redirectStatus = params.get('redirect_status');

    if (!paymentId) {
        return showError('Missing payment ID in URL.');
    }

    // If Stripe explicitly reported failure via redirect params — no need to poll.
    if (redirectStatus === 'failed') {
        return show('failed');
    }

    // Poll our API until we get a terminal status (webhook may arrive slightly after redirect).
    const TERMINAL = ['succeeded', 'failed', 'canceled', 'refunded', 'partially_refunded'];
    const MAX_ATTEMPTS = 8;
    const INTERVAL_MS  = 1500;

    let payment = null;

    for (let i = 0; i < MAX_ATTEMPTS; i++) {
        if (i > 0) {
            document.getElementById('loading-text').textContent = 'Waiting for confirmation…';
            await sleep(INTERVAL_MS);
        }
        try {
            const res = await fetch('/api/payments/' + paymentId);
            if (!res.ok) throw new Error('Payment not found.');
            payment = await res.json();
        } catch (e) {
            return showError(e.message);
        }

        if (TERMINAL.includes(payment.status)) break;
    }

    show(toUiState(payment.status), payment);

    // ── helpers ──────────────────────────────────────────────────────────────

    function toUiState(status) {
        if (status === 'succeeded')   return 'succeeded';
        if (status === 'failed' || status === 'canceled') return 'failed';
        return 'pending';
    }

    function show(state, payment) {
        ['loading', 'succeeded', 'pending', 'failed', 'error'].forEach(s => {
            document.getElementById('state-' + s).classList.toggle('hidden', s !== state);
        });

        if (payment && (state === 'succeeded' || state === 'pending')) {
            const detailsEl = document.getElementById('details-' + state);
            const amount    = (payment.amount / 100).toFixed(2);
            detailsEl.innerHTML = row('Amount', payment.currency.toUpperCase() + ' ' + amount)
                + row('Status', badge(state, payment.status))
                + row('Payment ID', '<span class="font-mono text-xs text-slate-400">' + payment.id + '</span>');
        }
    }

    function showError(msg) {
        document.getElementById('error-text').textContent = msg;
        show('error');
    }

    function row(label, value) {
        return '<div class="flex justify-between items-center text-sm">'
            + '<span class="text-slate-500">' + label + '</span>'
            + '<span class="font-medium text-slate-800">' + value + '</span>'
            + '</div>';
    }

    function badge(state, text) {
        const colors = {
            succeeded: 'bg-green-100 text-green-700',
            pending:   'bg-amber-100 text-amber-700',
            failed:    'bg-red-100 text-red-700',
        };
        return '<span class="px-2 py-0.5 rounded-full text-xs font-semibold ' + (colors[state] || '') + '">' + text + '</span>';
    }

    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
})();
</script>
{% endblock %}
